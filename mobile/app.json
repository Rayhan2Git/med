{
  "expo": {
    "name": "BD Medicine Price",
    "slug": "bd-medicine-price",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2F5BA2"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bdmedicine.price"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2F5BA2"
      },
      "package": "com.bdmedicine.price"
    },
    "plugins": [
      "expo-build-properties",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to photos for prescription scanning",
          "cameraPermission": "Allow access to camera for prescription scanning"
        }
      ]
    ]
  }
}